# ── WC2026 data feed — environment ──
# Copy this file to ".env". NEVER commit the real .env.

# Which feed to use:
#   free  (default) → football-data.org (free key) + RSS news. No tokens, no cost.
#   ai              → Claude + web search (richer, bilingual, but uses API tokens).
FEED=free

# ── FREE mode ──
# News refreshes with NO key at all (public RSS).
# For LIVE stats/scores/standings, get a FREE key (free signup, free calls):
#   https://www.football-data.org/client/register   (World Cup competition code: WC)
FOOTBALLDATA_KEY=

# ── OPTIONAL premium extras: possession / shots / xG in the match panel ──
# BALLDONTLIE FIFA API (GOAT tier, 48 h free trial): https://app.balldontlie.io
# Leave empty → the match panel shows goals/cards/referee only (still free).
BALLDONTLIE_KEY=

# ── AI mode (only needed if FEED=ai) ──
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WC_MODEL=claude-sonnet-4-6      # or claude-opus-4-8 for max quality
# WC_EFFORT=medium                # low | medium | high | max

# ── Common ──
PORT=3000
CACHE_TTL_MS=600000               # 10 min — how long a snapshot is reused before refetching
